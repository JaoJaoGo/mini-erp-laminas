<?php

declare(strict_types=1);

/** @var \Application\Entity\Product $product */
$product = $this->product;

$imagePath = $product->getImagePath();
$imageUrl = $imagePath ? '/' . ltrim($imagePath, '/') : 'https://via.placeholder.com/320x220?text=Produto';

$categories = $product->getCategories()->toArray();
?>

<div style="border: 1px solid #e5e7eb; border-radius: 16px; overflow: hidden; background: #fff; transition: all 0.2s ease; box-shadow: 0 8px 20px rgba(0, 0, 0, 0.04);">
    <div style="background: #f9fafb; height: 220px; display: flex; align-items: center; justify-content: center; padding: 16px;">
        <img
            src="<?= $this->escapeHtmlAttr($imageUrl) ?>"
            alt="<?= $this->escapeHtmlAttr($product->getName()) ?>"
            style="max-width: 100%; max-height: 100%; object-fit: contain; display: block;"
        >
    </div>

    <div style="padding: 18px;">
        <div style="min-height: 44px; margin-bottom: 10px;">
            <h3 style="margin: 0; font-size: 16px; line-height: 1.4; color: #111827;">
                <?= $this->escapeHtml($product->getName()) ?>
            </h3>
        </div>

        <div style="margin-bottom: 12px; min-height: 22px;">
            <?php if ($categories !== []): ?>
                <span style="display: inline-block; padding: 6px 10px; border-radius: 999px; background: #eff6ff; color: #1d4ed8; font-size: 12px; font-weight: 600;">
                    <?= $this->escapeHtml($categories[0]->getName()) ?>
                </span>
            <?php else: ?>
                <span style="display: inline-block; padding: 6px 10px; border-radius: 999px; background: #f3f4f6; color: #6b7280; font-size: 12px; font-weight: 600;">
                    Sem categoria
                </span>
            <?php endif; ?>
        </div>

        <div style="margin-bottom: 16px;">
            <p style="margin: 0; font-size: 26px; font-weight: 700; color: #111827;">
                R$ <?= number_format((float) $product->getPrice(), 2, ',', '.') ?>
            </p>
        </div>

        <a
            href="<?= $this->url('store/view', ['id' => (int) $product->getId()]) ?>"
            style="display: block; width: 100%; padding: 12px; border-radius: 999px; background: #ffd814; color: #111827; font-weight: 700; text-align: center; text-decoration: none; box-sizing: border-box;"
        >
            Ver detalhes
        </a>
    </div>
</div>