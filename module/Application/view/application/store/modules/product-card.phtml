<?php

declare(strict_types=1);

/** @var \Application\Entity\Product $product */
$product = $this->product;

$imagePath = $product->getImagePath();
$imageUrl = $imagePath ? '/' . ltrim($imagePath, '/') : '/img/product-placeholder.png';

$categories = $product->getCategories()->toArray();
$primaryCategory = $categories[0] ?? null;
?>

<article style="border: 1px solid #e5e7eb; border-radius: 16px; overflow: hidden; background: #fff; transition: all 0.2s ease; box-shadow: 0 8px 20px rgba(0, 0, 0, 0.04); display: flex; flex-direction: column; height: 100%;">
    <a
        href="<?= $this->url('store/view', ['id' => (int) $product->getId()]) ?>"
        style="background: #f9fafb; height: 240px; display: flex; align-items: center; justify-content: center; padding: 16px; text-decoration: none;"
    >
        <img
            src="<?= $this->escapeHtmlAttr($imageUrl) ?>"
            alt="<?= $this->escapeHtmlAttr($product->getName()) ?>"
            style="max-width: 100%; max-height: 100%; object-fit: contain; display: block;"
        >
    </a>

    <div style="padding: 18px; display: flex; flex-direction: column; gap: 12px; flex: 1;">
        <div style="min-height: 42px;">
            <a
                href="<?= $this->url('store/view', ['id' => (int) $product->getId()]) ?>"
                style="margin: 0; font-size: 16px; line-height: 1.4; color: #111827; text-decoration: none; font-weight: 600;"
            >
                <?= $this->escapeHtml($product->getName()) ?>
            </a>
        </div>

        <div style="min-height: 24px;">
            <?php if ($primaryCategory !== null): ?>
                <span style="display: inline-block; padding: 6px 10px; border-radius: 999px; background: #eff6ff; color: #1d4ed8; font-size: 12px; font-weight: 600;">
                    <?= $this->escapeHtml($primaryCategory->getName()) ?>
                </span>
            <?php else: ?>
                <span style="display: inline-block; padding: 6px 10px; border-radius: 999px; background: #f3f4f6; color: #6b7280; font-size: 12px; font-weight: 600;">
                    Sem categoria
                </span>
            <?php endif; ?>
        </div>

        <div>
            <p style="margin: 0; font-size: 26px; font-weight: 700; color: #111827;">
                R$ <?= number_format((float) $product->getPrice(), 2, ',', '.') ?>
            </p>
        </div>

        <div style="margin-top: auto; display: flex; flex-direction: column; gap: 10px;">
            <p style="margin: 0; font-size: 13px; color: <?= $product->getStock() > 0 ? '#166534' : '#991b1b' ?>; font-weight: 600;">
                <?= $product->getStock() > 0
                    ? 'Em estoque'
                    : 'Indisponível' ?>
            </p>

            <a
                href="<?= $this->url('store/view', ['id' => (int) $product->getId()]) ?>"
                style="display: block; width: 100%; padding: 12px; border-radius: 999px; background: #ffd814; color: #111827; font-weight: 700; text-align: center; text-decoration: none; box-sizing: border-box;"
            >
                Ver detalhes
            </a>
        </div>
    </div>
</article>