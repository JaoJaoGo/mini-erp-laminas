<?php

declare(strict_types=1);

/** @var \Application\Entity\Product $product */
$product = $this->product;

$categories = $product->getCategories()->toArray();
?>

<div style="display: grid; grid-template-columns: minmax(0, 1fr) 320px; gap: 24px; align-items: start;">
    <div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 18px; padding: 28px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);">
        <h2 style="margin: 0 0 18px; font-size: 24px; color: #111827;">
            Sobre este produto
        </h2>

        <div style="color: #374151; line-height: 1.7; font-size: 16px;">
            <?php if ($product->getDescription() !== null && trim($product->getDescription()) !== ''): ?>
                <p style="margin: 0;">
                    <?= nl2br($this->escapeHtml($product->getDescription())) ?>
                </p>
            <?php else: ?>
                <p style="margin: 0; color: #6b7280;">
                    Este produto ainda não possui descrição cadastrada.
                </p>
            <?php endif; ?>
        </div>
    </div>

    <aside style="display: flex; flex-direction: column; gap: 24px;">
        <div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 18px; padding: 24px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);">
            <h3 style="margin: 0 0 16px; font-size: 18px; color: #111827;">
                Informações rápidas
            </h3>

            <div style="display: flex; flex-direction: column; gap: 12px; font-size: 14px; color: #374151;">
                <div>
                    <strong>ID:</strong>
                    #<?= (int) $product->getId() ?>
                </div>

                <div>
                    <strong>Status:</strong>
                    <?= $product->isActive() ? 'Ativo' : 'Inativo' ?>
                </div>

                <div>
                    <strong>Estoque:</strong>
                    <?= (int) $product->getStock() ?>
                </div>

                <div>
                    <strong>Preço:</strong>
                    R$ <?= number_format((float) $product->getPrice(), 2, ',', '.') ?>
                </div>
            </div>
        </div>

        <div style="background: #fff; border: 1px solid #e5e7eb; border-radius: 18px; padding: 24px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.05);">
            <h3 style="margin: 0 0 16px; font-size: 18px; color: #111827;">
                Categorias
            </h3>

            <div style="display: flex; flex-wrap: wrap; gap: 10px;">
                <?php if ($categories === []): ?>
                    <span style="color: #6b7280; font-size: 14px;">
                        Sem categoria
                    </span>
                <?php else: ?>
                    <?php foreach ($categories as $category): ?>
                        <span style="display: inline-block; padding: 8px 12px; border-radius: 999px; background: #f3f4f6; color: #111827; font-size: 13px; font-weight: 600;">
                            <?= $this->escapeHtml($category->getName()) ?>
                        </span>
                    <?php endforeach; ?>
                <?php endif; ?>
            </div>
        </div>
    </aside>
</div>