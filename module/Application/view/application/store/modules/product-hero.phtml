                    <?php endforeach; ?>
                </div>
            <?php endif; ?>

            <h1 style="margin: 0 0 16px; font-size: 34px; line-height: 1.2; color: #111827; font-weight: 700;">
                <?= $this->escapeHtml($product->getName()) ?>
            </h1>

