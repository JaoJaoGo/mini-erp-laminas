<?php

declare(strict_types=1);

/** @var \Application\Entity\User|null $user */
$user = $this->user ?? null;

/** @var \Application\Entity\Category|null $category */
$category = $this->category ?? null;

/** @var \Application\Form\CategoryForm $form */
$form = $this->form;

$isEdit = $category !== null;
$title = $isEdit ? 'Editar categoria' : 'Nova categoria';

$form->prepare();

$nameElement = $form->get('name');
$descriptionElement = $form->get('description');
$csrfElement = $form->get('csrf');

$nameElement->setAttribute('style', 'width: 100%; padding: 12px 14px; border: 1px solid #d1d5db; border-radius: 8px; background: #fff; color: #111827;');
$descriptionElement->setAttribute('style', 'width: 100%; padding: 12px 14px; border: 1px solid #d1d5db; border-radius: 8px; background: #fff; color: #111827; resize: vertical;');

function renderFieldErrors(array $messages, $escapeHtml): string {
    if (empty($messages)) {
        return '';
    }

    $html = 'margin-bottom: 24px; padding: 16px; border-radius: 8px; background: #fee2e2; color: #991b1b; border: 1px solid #fecaca;';

    foreach ($messages as $message) {
        if (is_array($message)) {
            foreach ($message as $nestedMessage) {
                $html .= '<div>' . $escapeHtml($nestedMessage) . '</div>';
            }
        } else {
            $html .= '<div>' . $escapeHtml($message) . '</div>';
        }
    }

    $html .= '</div>';

    return $html;
}
?>

