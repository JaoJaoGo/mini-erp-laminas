<script>
    (function () {
        const selector = document.getElementById('category-selector');
        const container = document.getElementById('selected-categories');

        if (!selector || !container) {
            return;
        }

        function hasCategory(categoryId) {
            return container.querySelector('[data-category-id="' + CSS.escape(categoryId) + '"]') !== null;
        }

        function bindRemove(button) {
            button.addEventListener('click', function () {
                const item = button.closest('.selected-category-item');

                if (item) {
                    item.remove();
                }
            });
        }

        function createCategoryItem(categoryId, categoryName) {
            const item = document.createElement('div');
            item.className = 'selected-category-item';
            item.setAttribute('data-category-id', categoryId);
            item.style.display = 'inline-flex';
            item.style.alignItems = 'center';
            item.style.gap = '10px';
            item.style.padding = '10px 12px';
            item.style.borderRadius = '999px';
            item.style.background = '#eff6ff';
            item.style.border = '1px solid #bfdbfe';
            item.style.color = '#1e3a8a';
            item.style.fontSize = '14px';
            item.style.fontWeight = '600';

            const label = document.createElement('span');
            label.textContent = categoryName;

            const removeButton = document.createElement('button');
            removeButton.type = 'button';
            removeButton.className = 'remove-category-button';
            removeButton.textContent = '×';
            removeButton.style.width = '24px';
            removeButton.style.height = '24px';
            removeButton.style.border = '0';
            removeButton.style.borderRadius = '999px';
            removeButton.style.background = '#dbeafe';
            removeButton.style.color = '#1d4ed8';
            removeButton.style.fontWeight = '700';
            removeButton.style.cursor = 'pointer';
            removeButton.style.lineHeight = '1';

            const hidden = document.createElement('input');
            hidden.type = 'hidden';
            hidden.name = 'categories[]';
            hidden.value = categoryId;

            item.appendChild(label);
            item.appendChild(removeButton);
            item.appendChild(hidden);

            bindRemove(removeButton);

            return item;
        }

        container.querySelectorAll('.remove-category-button').forEach(bindRemove);

        selector.addEventListener('change', function () {
            const categoryId = selector.value;
            const categoryName = selector.options[selector.selectedIndex]?.text ?? '';

            if (!categoryId) {
                return;
            }

            if (!hasCategory(categoryId)) {
                container.appendChild(createCategoryItem(categoryId, categoryName));
            }

            selector.value = '';
        });
    })();
</script>

