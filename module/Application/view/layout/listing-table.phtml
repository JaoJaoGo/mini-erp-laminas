<?php

declare(strict_types=1);

/**
 * Espera receber:
 * - array $columns
 * - array $rows
 * - string|null $emptyMessage
 */
?>

<div style="overflow-x: auto; background: #fff; border: 1px solid #e5e7eb; border-radius: 16px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);">
    <table style="width: 100%; border-collapse: collapse; min-width: 760px;">
        <thead>
            <tr style="background: #f9fafb;">
                <?php foreach ($columns as $column): ?>
                    <th
                        style="
                            padding: 16px;
                            text-align: left;
                            font-size: 14px;
                            font-weight: 700;
                            color: #374151;
                            border-bottom: 1px solid #e5e7eb;
                        "
                    >
                        <?= $this->escapeHtml($column['label']) ?>
                    </th>
                <?php endforeach; ?>
            </tr>
        </thead>

        <tbody>
            <?php if (empty($rows)): ?>
                <tr>
                    <td
                        colspan="<?= count($columns) ?>"
                        style="
                            padding: 24px 16px;
                            text-align: center;
                            color: #6b7280;
                        "
                    >
                        <?= $this->escapeHtml($emptyMessage ?? 'Nenhum registro encontrado.') ?>
                    </td>
                </tr>
            <?php else: ?>
                <?php foreach ($rows as $row): ?>
                    <tr style="border-bottom: 1px solid #f3f4f6;">
                        <?php foreach ($columns as $column): ?>
                            <td style="padding: 16px; color: #111827; vertical-align: middle;">
                                <?php
                                $value = $row[$column['key']] ?? '';

                                if (($column['type'] ?? null) === 'html') {
                                    echo $value;
                                } else {
                                    echo $this->escapeHtml((string) $value);
                                }
                                ?>
                            </td>
                        <?php endforeach; ?>
                    </tr>
                <?php endforeach; ?>
            <?php endif; ?>
        </tbody>
    </table>
</div>