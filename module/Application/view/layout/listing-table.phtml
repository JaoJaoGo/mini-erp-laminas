<?php

declare(strict_types=1);

/**
 * Espera receber:
 * - array $columns
 * - array $rows
 * - string|null $emptyMessage
 */
?>

<div style="overflow-x: auto; background: #fff; margin: 20px; border: 1px solid #e5e7eb; border-radius: 16px; box-shadow: 0 10px 30px rgba(0, 0, 0, 0.06);">
    <table style="width: 100%; border-collapse: collapse; min-width: 760px;">
        <thead>
            <tr style="background: #f9fafb;">
                <?php foreach ($columns as $column): ?>
                    <th
                        style="
                            padding: 16px;
                            text-align: left;
                            font-size: 14px;
                            font-weight: 700;
                            color: #374151;
                            border-bottom: 1px solid #e5e7eb;
                        "
                    >
                        <?= $this->escapeHtml($column['label']) ?>
                    </th>
                <?php endforeach; ?>
            </tr>
        </thead>

        <tbody>
            <?php if (empty($rows)): ?>
                <tr>
                    <td
                        colspan="<?= count($columns) ?>"
                        style="
                            padding: 24px 16px;
                            text-align: center;
                            color: #6b7280;
                        "
                    >
                        <?= $this->escapeHtml($emptyMessage ?? 'Nenhum registro encontrado.') ?>
                    </td>
                </tr>
            <?php else: ?>
                <?php foreach ($rows as $row): ?>
                    <tr style="border-bottom: 1px solid #f3f4f6;">
                        <?php foreach ($columns as $column): ?>
                            <td style="padding: 16px; color: #111827; vertical-align: middle;">
                                <?php
                                $value = $row[$column['key']] ?? '';
                                $type = $column['type'] ?? null;

                                if ($type === 'html') {
                                    echo $value;
                                } elseif ($type === 'badges-fade') {
                                    $items = is_array($value) ? $value : [];
                                    ?>
                                    <div
                                        style="
                                            position: relative;
                                            max-width: 260px;
                                        "
                                    >
                                        <div
                                            style="
                                                display: flex;
                                                flex-wrap: nowrap;
                                                gap: 8px;
                                                overflow: hidden;
                                                white-space: nowrap;
                                                padding-right: 36px;
                                            "
                                        >
                                            <?php if ($items === []): ?>
                                                <span style="color: #6b7280;">-</span>
                                            <?php else: ?>
                                                <?php foreach ($items as $item): ?>
                                                    <span
                                                        style="
                                                            display: inline-flex;
                                                            align-items: center;
                                                            padding: 6px 10px;
                                                            border-radius: 999px;
                                                            background: #eff6ff;
                                                            border: 1px solid #bfdbfe;
                                                            color: #1e3a8a;
                                                            font-size: 12px;
                                                            font-weight: 600;
                                                            flex: 0 0 auto;
                                                        "
                                                    >
                                                        <?= $this->escapeHtml((string) $item) ?>
                                                    </span>
                                                <?php endforeach; ?>
                                            <?php endif; ?>
                                        </div>

                                        <?php if ($items !== []): ?>
                                            <div
                                                aria-hidden="true"
                                                style="
                                                    position: absolute;
                                                    top: 0;
                                                    right: 0;
                                                    width: 52px;
                                                    height: 100%;
                                                    pointer-events: none;
                                                    background: linear-gradient(to right, rgba(255,255,255,0), #fff 75%);
                                                "
                                            ></div>
                                        <?php endif; ?>
                                    </div>
                                    <?php
                                } else {
                                    echo $this->escapeHtml((string) $value);
                                }
                                ?>
                            </td>
                        <?php endforeach; ?>
                    </tr>
                <?php endforeach; ?>
            <?php endif; ?>
        </tbody>
    </table>
</div>