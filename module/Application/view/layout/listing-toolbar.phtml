<?php

declare(strict_types=1);

/**
 * Espera receber:
 * - string $title
 * - string $backRoute
 * - string $createRoute
 * - string $createLabel
 * - array $filters
 */
?>

<div style="display: flex; flex-direction: column; gap: 20px; margin-bottom: 24px;">
    <div style="display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 16px;">
        <div>
            <h1 style="margin: 0; font-size: 32px; color: #111827;">
                <?= $this->escapeHtml($title) ?>
            </h1>
        </div>

        <div style="display: flex; flex-wrap: wrap; gap: 12px;">
            <a href="<?= $this->url($backRoute) ?>"
                style="
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    padding: 12px 18px;
                    border-radius: 8px;
                    background: #374151;
                    color: #fff;
                    text-decoration: none;
                    font-weight: 600;
                "
            >
                Voltar
            </a>

            <a href="<?= $this->url($createRoute, ['action' => 'create']) ?>"
                style="
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    padding: 12px 18px;
                    border-radius: 8px;
                    background: #2563eb;
                    color: #fff;
                    text-decoration: none;
                    font-weight: 600;
                "
            >
                <?= $this->escapeHtml($createLabel) ?>
            </a>
        </div>
    </div>

    <form method="get" style="display: flex; flex-wrap: wrap; gap: 12px;">
        <?php foreach ($filters as $filter): ?>
            <div style="display: flex; flex-direction: column; min-width: 200px; flex: 1;">
                <label
                    for="<?= $this->escapeHtmlAttr($filter['name']) ?>"
                    style="margin-bottom: 6px; font-size: 14px; font-weight: 600; color: #374151;"
                >
                    <?= $this->escapeHtml($filter['label']) ?>
                </label>

                <input
                    type="<?= $this->escapeHtmlAttr($filter['type'] ?? 'text') ?>"
                    name="<?= $this->escapeHtmlAttr($filter['name']) ?>"
                    id="<?= $this->escapeHtmlAttr($filter['name']) ?>"
                    value="<?= $this->escapeHtmlAttr((string) ($filter['value'] ?? '')) ?>"
                    placeholder="<?= $this->escapeHtmlAttr($filter['placeholder'] ?? '') ?>"
                    style="
                        width: 100%;
                        padding: 12px;
                        border: 1px solid #d1d5db;
                        border-radius: 8px;
                        background: #fff;
                    "
                >
            </div>
        <?php endforeach; ?>

        <div style="display: flex; align-items: end; gap: 12px;">
            <button
                type="submit"
                style="
                    padding: 12px 18px;
                    border: 0;
                    border-radius: 8px;
                    background: #1d4ed8;
                    color: #fff;
                    font-weight: 600;
                    cursor: pointer;
                "
            >
                Filtrar
            </button>

            <a
                href=""
                style="
                    padding: 12px 18px;
                    border-radius: 8px;
                    background: #e5e7eb;
                    color: #111827;
                    text-decoration: none;
                    font-weight: 600;
                "
            >
                Limpar
            </a>
