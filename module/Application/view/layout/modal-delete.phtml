                padding: 24px;
                border-top: 1px solid #e5e7eb;
                display: flex;
                justify-content: flex-end;
                gap: 12px;
                flex-wrap: wrap;
            "
        >
            <button
                type="button"
                onclick="document.getElementById('<?= $this->escapeJs($modalId) ?>').style.display='none'"
