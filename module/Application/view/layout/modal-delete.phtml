                    background: #e5e7eb;
                    color: #111827;
                    font-weight: 600;
                    cursor: pointer;
                "
            >
                Cancelar
            </button>

            <a 
                href="<?= $this->escapeHtmlAttr($confirmUrl) ?>"
                style="
                    display: inline-flex;
                    align-items: center;
                    justify-content: center;
                    padding: 12px 18px;
                    border-radius: 8px;
                    background: #dc2626;
                    color: #fff;
                    text-decoration: none;
                    font-weight: 600;
                "
            >
                Apagar
            </a>
